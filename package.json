{
  "name": "personal-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:unit": "jest --testPathIgnorePatterns=e2e",
    "test:integration": "jest --testPathPattern=integration",
    "test:accessibility": "jest --testPathPattern=accessibility",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:accessibility": "playwright test tests/e2e/accessibility.spec.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:accessibility && npm run test:e2e",
    "perf:audit": "node scripts/performance-audit.js",
    "perf:lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "bundle:analyze": "npx @next/bundle-analyzer",
    "ci:build": "npm run type-check && npm run lint && npm run test:ci && npm run build",
    "ci:quality": "npm run lint && npm run format:check && npm run type-check",
    "migrate": "node scripts/run-migration.js",
    "migrate:content": "node scripts/migrate-content.js",
    "migrate:validate": "node scripts/validate-content.js",
    "migrate:images": "node scripts/optimize-images.js",
    "migrate:test": "node scripts/test-migration.js",
    "validate:ci": "node scripts/validate-ci-setup.js",
    "integration:final": "node scripts/run-final-integration.js",
    "integration:test": "node scripts/final-integration-test.js",
    "integration:cross-browser": "node scripts/cross-browser-test.js",
    "integration:deployment": "node scripts/deployment-validation.js",
    "integration:ux": "node scripts/user-experience-validation.js",
    "integration:quick": "node scripts/quick-integration-test.js",
    "cleanup": "node scripts/cleanup.js",
    "cleanup:deep": "node scripts/cleanup.js --deep",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "pwa:test": "npm run build && npx serve out -p 3000"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.5.0",
    "@types/lodash": "^4.17.20",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "framer-motion": "^12.23.12",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^2.26.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.541.0",
    "next": "15.5.0",
    "next-mdx-remote": "^5.0.0",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-extract-frontmatter": "^3.2.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-reading-time": "^2.0.2",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "workbox-webpack-plugin": "^7.3.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.12.0",
    "@next/bundle-analyzer": "^15.5.0",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.0.5",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^30.0.5",
    "lighthouse": "^12.2.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.1",
    "typescript": "^5"
  }
}
