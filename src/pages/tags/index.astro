---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TagTree from '../../components/TagTree.astro';
import TagGraph from '../../components/TagGraph';
import { buildTagTree, getGraphData } from '../../utils/tags';

const posts = (await getCollection('blog', ({ data }) => data.draft !== true)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tree = buildTagTree(posts);
const graphData = getGraphData(posts);
---

<Layout title="태그 - chan99k" description="태그별로 블로그 글을 탐색하세요.">
	<section class="py-8 sm:py-12">
		<h1 class="text-2xl sm:text-4xl font-bold mb-8 sm:mb-12">태그</h1>

		<TagGraph client:only="react" data={graphData} />

		<details class="mt-8">
			<summary class="cursor-pointer text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
				트리 뷰로 보기
			</summary>
			<div class="mt-4">
				<TagTree tree={tree} />
			</div>
		</details>
	</section>
</Layout>
