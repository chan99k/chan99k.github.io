---
import { getCollection } from 'astro:content';
import { buildTagTree, tagToSlug } from '../utils/tags';
import type { TagTreeNode } from '../utils/tags';
import SidebarTagNode from './SidebarTagNode.astro';

interface Props {
	currentTag?: string;
}

const { currentTag } = Astro.props;

const posts = await getCollection('blog', ({ data }) => data.draft !== true);
const tree = buildTagTree(posts);

const MAX_SIDEBAR_DEPTH = 4;
const MIN_POSTS_FOR_TIER4 = 3;

function renderTree(node: TagTreeNode, basePath: string = '', depth: number = 0): { name: string; fullPath: string; count: number; children: ReturnType<typeof renderTree> }[] {
	if (depth >= MAX_SIDEBAR_DEPTH) return [];

	return Object.entries(node.children)
		.sort(([a], [b]) => a.localeCompare(b))
		.filter(([_, child]) => {
			if (depth === 3 && child.count < MIN_POSTS_FOR_TIER4) return false;
			return true;
		})
		.map(([name, child]) => ({
			name,
			fullPath: basePath ? `${basePath}/${name}` : name,
			count: child.count,
			children: renderTree(child, basePath ? `${basePath}/${name}` : name, depth + 1),
		}));
}

const treeData = renderTree(tree);
---

<aside class="hidden lg:block w-48 shrink-0 py-12 pr-6 border-r border-black/[0.06] dark:border-white/[0.06]">
	<div class="sticky top-24">
		<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">카테고리</h2>
		<nav>
			<a
				href="/blog"
				class:list={[
					'no-underline block py-1.5 text-sm transition-colors',
					!currentTag
						? 'text-accent font-semibold'
						: 'text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white',
				]}
			>
				전체 글
			</a>
			<SidebarTagNode items={treeData} currentTag={currentTag} />
		</nav>
	</div>
</aside>
