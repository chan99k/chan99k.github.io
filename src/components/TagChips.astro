---
import { tagToSlug } from '../utils/tags';
import { getTagColor, COLOR_CLASSES } from '../data/tag-taxonomy';

interface Props {
	tags: string[];
	size?: 'sm' | 'md';
}

const { tags, size = 'sm' } = Astro.props;

const sizeClasses = {
	sm: 'text-xs px-2.5 py-0.5',
	md: 'text-sm px-3 py-1',
};

function getColorClass(tag: string): string {
	return COLOR_CLASSES[getTagColor(tag)];
}
---

<div class="flex flex-wrap gap-2">
	{tags.map((tag) => {
		const label = tag.includes('/') ? tag.split('/').pop() : tag;
		return (
			<a
				href={`/tags/${tagToSlug(tag)}/`}
				class:list={[
					'no-underline rounded-full font-medium transition-opacity hover:opacity-80',
					getColorClass(tag),
					sizeClasses[size],
				]}
			>
				{label}
			</a>
		);
	})}
</div>
