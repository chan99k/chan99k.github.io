---
import { type CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'portfolio'>;
}

const { entry } = Astro.props;

const categoryLabels = {
	problem: '문제 해결',
	decision: '의사결정',
} as const;

const categoryColors = {
	problem: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300',
	decision: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300',
} as const;
---

<a href={`/portfolio/${entry.slug}/`} class="group block no-underline">
    <div class="space-y-3 sm:space-y-4">
        <div class="aspect-video w-full overflow-hidden rounded-lg sm:rounded-xl bg-gradient-to-br from-accent/10 via-accent/5 to-transparent dark:from-accent/20 dark:via-accent/10 dark:to-transparent border border-gray-100 dark:border-gray-800 flex items-center justify-center transition-transform duration-500 group-hover:scale-105">
            <span class="text-2xl sm:text-3xl font-bold text-accent/30 dark:text-accent/40 select-none">{entry.data.title.charAt(0)}</span>
        </div>
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class={`px-2 py-0.5 text-xs font-medium rounded ${categoryColors[entry.data.category]}`}>
                    {categoryLabels[entry.data.category]}
                </span>
                <span class="px-2 py-0.5 text-xs font-medium bg-gray-100 dark:bg-gray-800 rounded">
                    {entry.data.project}
                </span>
            </div>
            <h3 class="text-lg sm:text-xl font-bold group-hover:underline decoration-accent underline-offset-4 mb-1.5 sm:mb-2">{entry.data.title}</h3>
            <p class="text-sm sm:text-base text-gray-500 dark:text-gray-400 leading-relaxed mb-3 sm:mb-4">
                {entry.data.description}
            </p>
            {entry.data.techStack && entry.data.techStack.length > 0 && (
                <div class="flex flex-wrap gap-1.5 sm:gap-2">
                    {entry.data.techStack.map(tech => (
                        <span class="px-2 py-0.5 sm:py-1 text-xs font-medium bg-gray-100 dark:bg-gray-800 rounded">
                            {tech}
                        </span>
                    ))}
                </div>
            )}
        </div>
    </div>
</a>
