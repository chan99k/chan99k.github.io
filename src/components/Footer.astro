---
import { SITE } from '../config/site';
---

<footer class="py-10 sm:py-16 mt-auto border-t border-gray-100 dark:border-gray-800">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 max-w-7xl mx-auto px-5 sm:px-10 lg:px-24">
        <div class="flex items-center gap-6">
            <a href={SITE.social.github} target="_blank" class="text-sm font-medium hover:text-accent transition-colors">GitHub</a>
            <a href={SITE.social.linkedin} target="_blank" class="text-sm font-medium hover:text-accent transition-colors">LinkedIn</a>
        </div>

        <p class="text-sm text-gray-400">
            &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.
        </p>

        <div class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-lg border border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-900/50 text-xs text-gray-400">
            <span>Search</span>
            <kbd class="font-mono bg-white dark:bg-navy-900 px-1.5 py-0.5 rounded border border-gray-200 dark:border-gray-700">⌘</kbd>
            <kbd class="font-mono bg-white dark:bg-navy-900 px-1.5 py-0.5 rounded border border-gray-200 dark:border-gray-700">K</kbd>
        </div>
    </div>
</footer>
